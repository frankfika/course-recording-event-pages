        "好",
        "\"你好\" → 1~2 Token",
        "Hello",
        "\"Hello\" → 1 Token",
        "人工",
        "智能",
        "\"人工智能\" → 2~3 Token",
        "$",
        "Token 决定价格",
        "用得越多，花得越多",
        "Token 决定记忆力",
        "上下文窗口有限",
        "Tokenizer"
      ],
