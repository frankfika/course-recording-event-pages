      "slide_num": 6,
      "texts": [
        "大模型 = 看过海量文本的超级学霸",
        "看过海量百科、新闻和论坛内容",
        "见过大量代码和技术文档",
        "学过很多书里的表达方式",
        "擅长从海量文本里总结模式",
        "但它不是真的理解——它学到的，本质上是语言的模式"
      ],
      "images": [
        {
          "name": "Image 0",
          "file": "images/slide6_Image_0.jpg",
